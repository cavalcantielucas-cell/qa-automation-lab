{
  "info": {
    "name": "JSONPlaceholder API Tests",
    "description": "Coleção de testes de API para portfólio QA usando Postman e Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET - Listar usuários",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code deve ser 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta deve ser uma lista de usuários', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "  pm.expect(jsonData.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Primeiro usuário deve possuir campos obrigatórios', function () {",
              "  const user = pm.response.json()[0];",
              "  pm.expect(user).to.have.property('id');",
              "  pm.expect(user).to.have.property('name');",
              "  pm.expect(user).to.have.property('username');",
              "  pm.expect(user).to.have.property('email');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET - Buscar post por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "{{postId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code deve ser 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Post retornado deve ter o ID esperado', function () {",
              "  const jsonData = pm.response.json();",
              "  const expectedPostId = Number(pm.environment.get('postId'));",
              "  pm.expect(jsonData.id).to.eql(expectedPostId);",
              "});",
              "",
              "pm.test('Post deve possuir título e body', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.title).to.be.a('string');",
              "  pm.expect(jsonData.body).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST - Criar novo post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Projeto QA Automation Lab\",\n  \"body\": \"Criando testes de API com Postman para portfólio QA.\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code deve ser 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Resposta deve retornar os dados enviados', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.title).to.eql('Projeto QA Automation Lab');",
              "  pm.expect(jsonData.body).to.eql('Criando testes de API com Postman para portfólio QA.');",
              "  pm.expect(jsonData.userId).to.eql(1);",
              "});",
              "",
              "pm.test('Resposta deve retornar um ID', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET - Buscar recurso inexistente",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/999999",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "999999"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code deve ser 404', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}