{
  "info": {
    "name": "JSONPlaceholder API Tests",
    "description": "Coleção de testes de API para portfólio QA, validando status code, estrutura de resposta e dados esperados.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "GET - Listar usuários",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Resposta deve ser uma lista de usuários', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.be.an('array');",
                  "  pm.expect(jsonData.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Primeiro usuário deve possuir campos obrigatórios', function () {",
                  "  const user = pm.response.json()[0];",
                  "  pm.expect(user).to.have.property('id');",
                  "  pm.expect(user).to.have.property('name');",
                  "  pm.expect(user).to.have.property('username');",
                  "  pm.expect(user).to.have.property('email');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET - Buscar usuário por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Usuário retornado deve ter o ID esperado', function () {",
                  "  const jsonData = pm.response.json();",
                  "  const expectedUserId = Number(pm.environment.get('userId'));",
                  "  pm.expect(jsonData.id).to.eql(expectedUserId);",
                  "});",
                  "",
                  "pm.test('Usuário deve possuir e-mail válido', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.email).to.include('@');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "GET - Listar posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Resposta deve ser uma lista de posts', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.be.an('array');",
                  "  pm.expect(jsonData.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Primeiro post deve possuir campos obrigatórios', function () {",
                  "  const post = pm.response.json()[0];",
                  "  pm.expect(post).to.have.property('userId');",
                  "  pm.expect(post).to.have.property('id');",
                  "  pm.expect(post).to.have.property('title');",
                  "  pm.expect(post).to.have.property('body');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET - Buscar post por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Post retornado deve ter o ID esperado', function () {",
                  "  const jsonData = pm.response.json();",
                  "  const expectedPostId = Number(pm.environment.get('postId'));",
                  "  pm.expect(jsonData.id).to.eql(expectedPostId);",
                  "});",
                  "",
                  "pm.test('Post deve possuir título e body', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.title).to.be.a('string');",
                  "  pm.expect(jsonData.body).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST - Criar novo post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Projeto QA Automation Lab\",\n  \"body\": \"Criando testes de API com Postman para portfólio QA.\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Resposta deve retornar os dados enviados', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.title).to.eql('Projeto QA Automation Lab');",
                  "  pm.expect(jsonData.body).to.eql('Criando testes de API com Postman para portfólio QA.');",
                  "  pm.expect(jsonData.userId).to.eql(1);",
                  "});",
                  "",
                  "pm.test('Resposta deve retornar um ID', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('id');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Negative Tests",
      "item": [
        {
          "name": "GET - Buscar recurso inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/999999",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "999999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Resposta deve retornar objeto vazio', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}